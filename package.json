{
  "name": "express-better-auth-poc",
  "private": true,
  "type": "module",
  "main": "./src/app.ts",
  "scripts": {
    "dev": "bun --hot src/app.ts",
    "type-check": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push:local": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun --env-file=.env src/db/seed.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "express": "^5.2.1",
    "mysql2": "^3.22.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "drizzle-kit": "^1.0.0-rc.4",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
