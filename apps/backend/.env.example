# MySQL database configuration
MYSQL_DATABASE=my_app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_PORT=3307

# Drizzle ORM configuration
DATABASE_URL=mysql://<user>:<password>@<host>:<port>/<database>
# Example:
# DATABASE_URL=mysql://app_user:app_password@127.0.0.1:3307/my_app_db

# Better Auth configuration
# A secret key for Better Auth, generate it using `openssl rand -base64 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000 # Base URL of your app

# Frontend origin (Vite default). Used for Express CORS and Better Auth trustedOrigins
FRONTEND_URL=http://localhost:5173
